# Development database
DATABASE_URL=postgres://user:password@localhost:5432/edren

# Secret for signing JWT tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

PORT=3000

# For running tests, pass a different DATABASE_URL on the command line:
# DATABASE_URL=postgres://user:password@localhost:5432/edren_test JWT_SECRET=test-secret npm test
